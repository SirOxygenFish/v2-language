// ── Batch 12 Tests ─────────────────────────────────────
let passed = 0
let failed = 0

func assert_eq(a, b, msg) {
    if (a == b) {
        passed += 1
    } else {
        println(f"FAIL: ${msg} | expected ${b}, got ${a}")
        failed += 1
    }
}

func assert_err(fn_to_call, msg) {
    try {
        fn_to_call()
        println(f"FAIL: ${msg} | expected error")
        failed += 1
    } catch (e) {
        passed += 1
    }
}

// ── 1. Computed Properties: getter + setter ────────────
class Temperature {
    func init(c) {
        self._celsius = c
    }

    get celsius -> float {
        return self._celsius
    }

    set celsius(value) {
        self._celsius = value
    }

    get fahrenheit -> float {
        return self._celsius * 9 / 5 + 32
    }

    set fahrenheit(value) {
        self.celsius = (value - 32) * 5 / 9
    }
}

let t = new Temperature(100)
assert_eq(t.celsius, 100, "computed property: getter returns backing field")
assert_eq(t.fahrenheit, 212, "computed property: derived getter works")
t.fahrenheit = 32
assert_eq(t.celsius, 0, "computed property: setter updates backing field")

// ── 2. Read-only computed property ─────────────────────
class Circle {
    func init(radius) {
        self.radius = radius
    }

    get area -> float {
        return self.radius * self.radius
    }
}

let c = new Circle(5)
assert_eq(c.area, 25, "computed property: read-only getter works")
assert_err(lambda() {
    c.area = 10
}, "computed property: read-only property rejects assignment")

// ── Summary ────────────────────────────────────────────
println(f"Batch 12: ${passed} passed, ${failed} failed")