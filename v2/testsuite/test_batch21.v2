let pass = 0
let fail = 0

func check(lbl, got, expected) {
    if (got == expected) {
        print("PASS: " + lbl)
        pass = pass + 1
    } else {
        print("FAIL: " + lbl + " | got=" + str(got) + " expected=" + str(expected))
        fail = fail + 1
    }
}

// ══════════════════════════════════════════════════════════════
// CH: Getting Started
// ══════════════════════════════════════════════════════════════
check("getting started - print works", 1, 1)

// ══════════════════════════════════════════════════════════════
// CH: Comments & Doc Comments
// ══════════════════════════════════════════════════════════════
// single line comment
/* multi-line
   comment */
/// doc comment on next func
func documented_fn() { return 42 }
check("doc comment func runs", documented_fn(), 42)

// ══════════════════════════════════════════════════════════════
// CH: Variables & Constants
// ══════════════════════════════════════════════════════════════
let x = 10
const PI = 3.14159
check("let variable", x, 10)
check("const", PI, 3.14159)

// ══════════════════════════════════════════════════════════════
// CH: Variable Scoping Rules
// ══════════════════════════════════════════════════════════════
let outer = 1
{
    let inner = 2
    outer = 3
}
check("scoping - outer updated", outer, 3)

// ══════════════════════════════════════════════════════════════
// CH: Data Types
// ══════════════════════════════════════════════════════════════
check("int type", typeof(42), "int")
check("float type", typeof(3.14), "float")
check("str type", typeof("hello"), "str")
check("bool type", typeof(true), "bool")
check("null type", typeof(null), "null")
check("list type", typeof([1,2,3]), "list")
check("dict type", typeof({"a": 1}), "dict")
check("tuple type", typeof((1,2)), "tuple")

// ══════════════════════════════════════════════════════════════
// CH: Operators
// ══════════════════════════════════════════════════════════════
check("add", 2 + 3, 5)
check("sub", 10 - 4, 6)
check("mul", 3 * 7, 21)
check("div", 10 / 2, 5)
check("mod", 10 % 3, 1)
check("power", 2 ** 3, 8)
check("eq", 5 == 5, true)
check("neq", 5 != 4, true)
check("lt", 3 < 5, true)
check("gt", 5 > 3, true)
check("and", true and false, false)
check("or", true or false, true)
check("not", not false, true)
// bitwise ops: &/| conflict with parser union types
check("bitxor", 6 ^ 3, 5)
check("shl", 1 << 3, 8)
check("shr", 8 >> 2, 2)

// CH: Operator Precedence (tested via expression)
check("precedence", 2 + 3 * 4, 14)

// ══════════════════════════════════════════════════════════════
// CH: F-String Reference
// ══════════════════════════════════════════════════════════════
let name = "world"
check("fstring", f"hello ${name}", "hello world")

// ══════════════════════════════════════════════════════════════
// CH: Strings
// ══════════════════════════════════════════════════════════════
check("str len", len("abc"), 3)
check("str upper", "hello".upper(), "HELLO")
check("str lower", "HELLO".lower(), "hello")
check("str trim", "  hi  ".trim(), "hi")
check("str contains", "hello world".contains("world"), true)
check("str split", "a,b,c".split(","), ["a", "b", "c"])
check("str starts_with", "abc".starts_with("ab"), true)
check("str ends_with", "abc".ends_with("bc"), true)
check("str replace", "abcabc".replace("a", "x"), "xbcxbc")
check("str index", "hello"[1], "e")
check("str slice", "hello"[1:3], "el")
check("str repeat", "ab".repeat(3), "ababab")

// ══════════════════════════════════════════════════════════════
// CH: Lists
// ══════════════════════════════════════════════════════════════
let lst = [1, 2, 3]
lst.push(4)
check("list push", lst, [1, 2, 3, 4])
check("list len", len(lst), 4)
check("list index", lst[0], 1)
check("list slice", lst[1:3], [2, 3])
check("list contains", lst.contains(2), true)
let popped = lst.pop()
check("list pop", popped, 4)
check("list map", [1,2,3].map(lambda(x) => x * 2), [2,4,6])
check("list filter", [1,2,3,4].filter(lambda(x) => x > 2), [3,4])
check("list reduce", [1,2,3].reduce(lambda(a,b) => a + b, 0), 6)
check("list sort", [3,1,2].sort(), [1,2,3])
check("list reverse", [1,2,3].reverse(), [3,2,1])
check("list join", ["a","b","c"].join("-"), "a-b-c")
check("list enumerate", [10,20].enumerate(), [(0,10),(1,20)])
check("list zip", [1,2].zip([3,4]), [(1,3),(2,4)])
check("list unique", [1,2,2,3].unique(), [1,2,3])
check("list flatten", [[1,2],[3,4]].flatten(), [1,2,3,4])

// ══════════════════════════════════════════════════════════════
// CH: Dictionaries
// ══════════════════════════════════════════════════════════════
let d = {"a": 1, "b": 2, "c": 3}
check("dict get", d["a"], 1)
check("dict has", d.has("b"), true)
check("dict keys len", len(d.keys()), 3)
check("dict values len", len(d.values()), 3)
let d2 = d.merge({"d": 4})
check("dict merge", d2["d"], 4)
check("dict pick", d.pick(["a","b"]), {"a": 1, "b": 2})
check("dict omit", d.omit(["c"]), {"a": 1, "b": 2})

// ══════════════════════════════════════════════════════════════
// CH: Tuples
// ══════════════════════════════════════════════════════════════
let t = (1, "two", 3.0)
check("tuple index", t[0], 1)
check("tuple len", t.len(), 3)
check("tuple first", t.first(), 1)
check("tuple last", t.last(), 3.0)
check("tuple to_list", t.to_list(), [1, "two", 3.0])

// ══════════════════════════════════════════════════════════════
// CH: Sets
// ══════════════════════════════════════════════════════════════
let s = #{1, 2, 3}
check("set type", typeof(s), "set")
check("set union", s.union(#{3, 4}), #{1, 2, 3, 4})
check("set intersect", s.intersect(#{2, 3, 4}), #{2, 3})
check("set diff", s.difference(#{2}), #{1, 3})

// ══════════════════════════════════════════════════════════════
// CH: Control Flow
// ══════════════════════════════════════════════════════════════
let cf_result = 0
if (true) { cf_result = 1 }
check("if true", cf_result, 1)

if (false) { cf_result = 99 } else { cf_result = 2 }
check("if-else", cf_result, 2)

let cf_sum = 0
for (i in 0..5) { cf_sum = cf_sum + i }
check("for range", cf_sum, 10)

let wh = 0
while (wh < 3) { wh = wh + 1 }
check("while", wh, 3)

// ternary
check("ternary", (true ? "yes" : "no"), "yes")

// null coalescing
check("null coalesce", null ?? "default", "default")
check("null coalesce non-null", "val" ?? "default", "val")

