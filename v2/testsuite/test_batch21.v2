// ══════════════════════════════════════════════════════════════
// CH: Operator Overloading
// ══════════════════════════════════════════════════════════════
class Vec2 {
    func constructor(x, y) {
        self.x = x
        self.y = y
    }
    func __add__(other) { return new Vec2(self.x + other.x, self.y + other.y) }
    func __eq__(other) { return self.x == other.x and self.y == other.y }
}
let va = new Vec2(1, 2)
let vb = new Vec2(3, 4)
let vc = va + vb
check("op overload add", vc.x, 4)
check("op overload add y", vc.y, 6)

