check("lazy eval", lazy_val, 3)

// ══════════════════════════════════════════════════════════════
// CH: Classes
// ══════════════════════════════════════════════════════════════
class Animal {
    func constructor(name) {
        self.name = name
        self.sound = "..."
    }
    func speak() {
        return self.name + " says " + self.sound
    }
}
let cat = new Animal("Cat")
cat.sound = "Meow"
check("class basic", cat.speak(), "Cat says Meow")

// Inheritance
class Dog extends Animal {
    func constructor(name, breed) {
        super(name)
        self.breed = breed
        self.sound = "Woof"
    }
    func info() {
        return f"${self.name} (${self.breed})"
    }
}
let d1 = new Dog("Rex", "Husky")
check("class inherit", d1.speak(), "Rex says Woof")
check("class child method", d1.info(), "Rex (Husky)")

// ══════════════════════════════════════════════════════════════
// CH: Fixed-Field Classes (@fixed)
// ══════════════════════════════════════════════════════════════
@fixed
class Point {
    func constructor(x, y) {
        self.x = x
        self.y = y
    }
}
let p = new Point(1, 2)
check("fixed class field", p.x, 1)

// ══════════════════════════════════════════════════════════════
// CH: Data Classes (@data)
// ══════════════════════════════════════════════════════════════
@data
class Vec2D {
    func constructor(x, y) {
        self.x = x
        self.y = y
    }
}
let v1 = new Vec2D(3, 4)
check("data class", v1.x, 3)

// ══════════════════════════════════════════════════════════════
// CH: Sealed Classes
// ══════════════════════════════════════════════════════════════
sealed class Shape {}
class Circle extends Shape {
    func constructor(r) { self.r = r }
}
class Rect extends Shape {
    func constructor(w, h) {
        self.w = w
        self.h = h
    }
}
let c1 = new Circle(5)
check("sealed class", c1.r, 5)

// ══════════════════════════════════════════════════════════════
// CH: Copy-on-Write Classes (@cow)
// ══════════════════════════════════════════════════════════════
@cow
class Buffer {
    func constructor(data) { self.data = data }
}
let b1 = new Buffer([1,2,3])
check("cow class", b1.data, [1,2,3])

