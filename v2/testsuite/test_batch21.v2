// ══════════════════════════════════════════════════════════════
// CH: Traits
// ══════════════════════════════════════════════════════════════
trait Greetable {
    func greet_msg() { return "" }
}

class Person {
    func constructor(name) { self.name = name }
}

impl Greetable for Person {
    func greet_msg() {
        return "Hi, I'm " + self.name
    }
}
let person = new Person("Alice")
check("trait impl", person.greet_msg(), "Hi, I'm Alice")

// impl block without trait
impl Person {
    func farewell() {
        return "Goodbye from " + self.name
    }
}
check("impl block", person.farewell(), "Goodbye from Alice")

// ══════════════════════════════════════════════════════════════
// CH: Pipe and Spread
// ══════════════════════════════════════════════════════════════
func inc(x) { return x + 1 }
func dbl(x) { return x * 2 }
check("pipe", 5 |> inc |> dbl, 12)

let arr = [1, 2, 3]
let arr2 = [0, ...arr, 4]
check("spread", arr2, [0, 1, 2, 3, 4])

