// ══════════════════════════════════════════════════════════════
// CH: Block Expressions
// ══════════════════════════════════════════════════════════════
let blk = do {
    let tmp = 10
    tmp * 2
}
check("block expr", blk, 20)

// ══════════════════════════════════════════════════════════════
// CH: Comprehensions
// ══════════════════════════════════════════════════════════════
let comp = [x * x for x in range(4)]
check("list comprehension", comp, [0, 1, 4, 9])

let dict_comp = {str(k): k * 2 for k in range(3)}
check("dict comprehension", dict_comp["1"], 2)

let set_comp = #{x % 3 for x in range(6)}
check("set comprehension", set_comp, #{0, 1, 2})

