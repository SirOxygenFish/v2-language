// ══════════════════════════════════════════════════════════════
// CH: Do Blocks
// ══════════════════════════════════════════════════════════════
let do_r = do {
    let a = 10
    let b = 20
    a + b
}
check("do block", do_r, 30)

// ══════════════════════════════════════════════════════════════
// CH: Bitfield Structs
// ══════════════════════════════════════════════════════════════
bitfield struct Permissions : u8 {
    read: 1,
    write: 1,
    exec: 1
}
check("bitfield struct defined", typeof(Permissions), "dict")

