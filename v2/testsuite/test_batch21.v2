if let Some(val) = opt {
    check("if let Some", val, 42)
}

// ══════════════════════════════════════════════════════════════
// CH: Labeled Loops
// ══════════════════════════════════════════════════════════════
let ll_result = 0
outer: for (let i = 0; i < 3; i = i + 1) {
    for (let j = 0; j < 3; j = j + 1) {
        if (j == 1) { break outer }
        ll_result = ll_result + 1
    }
}
check("labeled break", ll_result, 1)

