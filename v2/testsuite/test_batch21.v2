// CH: Decorators
// ══════════════════════════════════════════════════════════════
func my_decorator(f) {
    return lambda() => f()
}

@my_decorator
func decorated() { return "decorated" }
check("decorator", decorated(), "decorated")

// ══════════════════════════════════════════════════════════════
// CH: Lambdas & Closures
// ══════════════════════════════════════════════════════════════
let double = lambda(x) => x * 2
check("lambda", double(5), 10)

func make_counter() {
    let count = 0
    return lambda() {
        count = count + 1
        return count
    }
}
let counter = make_counter()
check("closure 1", counter(), 1)
check("closure 2", counter(), 2)

