check("callable int", callable(42), false)
print("checkpoint: before enum")

// ══════════════════════════════════════════════════════════════
// CH: Enums
// ══════════════════════════════════════════════════════════════
enum Direction {
    North,
    South,
    East,
    West
}
check("enum", str(Direction.North), "Direction.North")

// ══════════════════════════════════════════════════════════════
// CH: Pattern Matching
// ══════════════════════════════════════════════════════════════
func classify(val) {
    return match (val) {
        case (0) { "zero" }
        case (1) { "small" }
        case (2) { "small" }
        case (3) { "small" }
        case (_) { "other" }
    }
}
check("match 0", classify(0), "zero")
check("match 2", classify(2), "small")
check("match 99", classify(99), "other")

// ══════════════════════════════════════════════════════════════
// CH: Error Handling
// ══════════════════════════════════════════════════════════════
let err_result = 0
try {
    err_result = 42
} catch (e) {
    err_result = -1
}
check("try/catch ok", err_result, 42)

let err_result2 = ""
try {
    throw "oops"
} catch (e) {
    err_result2 = "caught"
}
check("try/catch err", err_result2, "caught")

// Result types
check("Ok unwrap", Ok(42).unwrap(), 42)
check("Err unwrap_or", Err("bad").unwrap_or(0), 0)
check("Ok is_ok", Ok(1).is_ok(), true)
check("Err is_err", Err("x").is_err(), true)
check("Some unwrap", Some(5).unwrap(), 5)
check("None unwrap_or", None.unwrap_or(0), 0)

// ══════════════════════════════════════════════════════════════
// CH: Generators
// ══════════════════════════════════════════════════════════════
func* range_gen(n) {
    let i = 0
    while (i < n) {
        yield i
        i = i + 1
    }
}
let gen_result = []
for (v in range_gen(3)) {
    gen_result.push(v)
}
check("generator", gen_result, [0, 1, 2])

