func add(a, b) { return a + b }
check("func call", add(3, 4), 7)

func greet(name, greeting = "Hello") { return f"${greeting}, ${name}!" }
check("func default params", greet("Bob"), "Hello, Bob!")
check("func named params", greet("Bob", "Hi"), "Hi, Bob!")

func variadic(...args) { return args }
check("variadic", variadic(1, 2, 3), [1, 2, 3])

