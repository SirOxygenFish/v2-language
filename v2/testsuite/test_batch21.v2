check("math.floor", math.floor(3.7), 3)
check("math.ceil", math.ceil(3.2), 4)
check("math.abs", math.abs(-5.0), 5.0)
check("math.sin", typeof(math.sin(1.0)), "float")
check("math.cos", typeof(math.cos(1.0)), "float")
check("math.log", typeof(math.log(2.0)), "float")
check("math.pow", math.pow(2.0, 3.0), 8.0)
check("math.min", math.min(1.0, 2.0), 1.0)
check("math.max", math.max(1.0, 2.0), 2.0)

