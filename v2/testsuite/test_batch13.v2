// ── Batch 13 Tests ─────────────────────────────────────
let passed = 0
let failed = 0

func assert_eq(a, b, msg) {
    if (a == b) {
        passed += 1
    } else {
        println(f"FAIL: ${msg} | expected ${b}, got ${a}")
        failed += 1
    }
}

// ── 1. @cow nested mutation detaches ───────────────────
@cow
class Buffer {
    func init(data) {
        self.data = data
    }

    func append(byte) {
        self.data.push(byte)
    }

    func len() {
        return len(self.data)
    }
}

let a = new Buffer([1, 2, 3])
let b = a
assert_eq(a.len(), 3, "@cow: original length before mutation")
assert_eq(b.len(), 3, "@cow: copy shares initial length")
b.append(4)
assert_eq(a.len(), 3, "@cow: original unchanged after nested field mutation")
assert_eq(b.len(), 4, "@cow: mutated copy detached on nested field mutation")

// ── 2. @cow direct field assignment detaches ───────────
@cow
class Point {
    func init(x, y) {
        self.x = x
        self.y = y
    }
}

let p1 = new Point(1, 2)
let p2 = p1
p2.x = 9
assert_eq(p1.x, 1, "@cow: original unchanged after direct field assignment")
assert_eq(p2.x, 9, "@cow: assigned copy detached on direct field assignment")
assert_eq(p1.y, 2, "@cow: untouched fields remain intact on original")

// ── Summary ────────────────────────────────────────────
println(f"Batch 13: ${passed} passed, ${failed} failed")