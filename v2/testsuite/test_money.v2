// std.money — currency-safe arithmetic on exact decimals.
import "std.money"
let passed = 0
let failed = 0
func check(name, got, want) {
    if (str(got) == str(want)) {
        passed = passed + 1
    } else {
        failed = failed + 1
        println(f"FAIL: ${name}: got ${got} want ${want}")
    }
}

check("add", money.format(money.add(money.new("10.25", currency: "USD"), money.new("2.10", currency: "USD"))), "USD 12.35")
check("sub", money.format(money.sub(money.new("10.00", currency: "USD"), money.new("3.50", currency: "USD"))), "USD 6.50")
check("mul", money.format(money.mul(money.new("10.00", currency: "USD"), 3)), "USD 30.00")
check("div half_even", money.format(money.div(money.new("10.00", currency: "USD"), 3)), "USD 3.33")
check("round half_even", money.round(money.new("2.345", currency: "USD"), scale: 2, mode: "HALF_EVEN")["amount"], "2.34")
check("round half_up", money.round(money.new("2.345", currency: "USD"), scale: 2, mode: "HALF_UP")["amount"], "2.35")
check("round down", money.round(money.new("2.999", currency: "USD"), scale: 0, mode: "DOWN")["amount"], "2")
check("compare", money.compare(money.new("5", currency: "USD"), money.new("10", currency: "USD")), -1)
check("convert", money.format(money.convert(money.new("100", currency: "USD"), to: "EUR", rates: money.rates({"USD/EUR": "0.92"}))), "EUR 92.00")

// currency mismatch must throw
let threw = false
try {
    money.add(money.new("1", currency: "USD"), money.new("1", currency: "EUR"))
} catch (e) {
    threw = true
}
check("mismatch throws", threw, true)

println(f"money: ${passed} passed, ${failed} failed")
assert_eq(failed, 0)
