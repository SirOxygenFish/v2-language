// ═══════════════════════════════════════════════════════════
// CH41: Destructuring Assignment
// ═══════════════════════════════════════════════════════════
let [da, db, dc] = [10, 20, 30]
check("destructure list", db, 20)
let (ta, tb) = (100, 200)
check("destructure tuple", ta, 100)

// ═══════════════════════════════════════════════════════════
// CH42: if let / while let
// ═══════════════════════════════════════════════════════════
let opt2 = Some(42)
check("if let Some", opt2.unwrap(), 42)

// ═══════════════════════════════════════════════════════════
// CH43: Labeled Loops
// ═══════════════════════════════════════════════════════════
let lbl_result = 0
outer: for (i in 0..5) {
    for (j in 0..5) {
        if (j == 2) { break outer }
        lbl_result = lbl_result + 1
    }
}
check("labeled break", lbl_result, 2)

// ═══════════════════════════════════════════════════════════
// CH44: Comprehensions
// ═══════════════════════════════════════════════════════════
let squares = [x * x for x in range(5)]
check("list comp", squares, [0, 1, 4, 9, 16])

// ═══════════════════════════════════════════════════════════
// CH45: Block Expressions
// ═══════════════════════════════════════════════════════════
let blk_a = 10
let blk_b = 20
check("block expr", blk_a + blk_b, 30)

// ═══════════════════════════════════════════════════════════
// CH46: Do Blocks
// ═══════════════════════════════════════════════════════════
let do_x = 5
let do_y = 10
check("do block", do_x + do_y, 15)

// ═══════════════════════════════════════════════════════════
// CH47: Runtime Introspection
// ═══════════════════════════════════════════════════════════
check("typeof", typeof(42), "int")
check("typeof()", typeof([1,2]), "list")

// ═══════════════════════════════════════════════════════════
// DONE — Summary
// ═══════════════════════════════════════════════════════════
print(f"PASS: ${pass} | FAIL: ${fail}")
if (fail > 0) {
    print("SOME TESTS FAILED")
}
