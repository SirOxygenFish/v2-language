// Chapter verification tests
// Each section tests one chapter from DOCS.md
// Uses check() pattern: PASS/FAIL output, exit code 0

let pass = 0
let fail = 0
func check(lbl, got, expected) {
    if (got == expected) {
        pass = pass + 1
    } else {
        fail = fail + 1
        print(f"FAIL: ${lbl} | got=${got} expected=${expected}")
    }
}

// ═══════════════════════════════════════════════════════════
// CH01: Getting Started
// ═══════════════════════════════════════════════════════════
// print("Hello, World!") is the canonical example
check("hello", "Hello, World!", "Hello, World!")

// ═══════════════════════════════════════════════════════════
// CH02: Comments & Doc Comments
// ═══════════════════════════════════════════════════════════
// Single-line comment
/* Multi-line
   comment */
/// Doc comment
check("comments parse", true, true)

// ═══════════════════════════════════════════════════════════
// CH03: Variables & Constants
// ═══════════════════════════════════════════════════════════
let name = "Alice"
let age = 30
let pi_val = 3.14159
let active = true
let nothing = null
const MAX_SIZE = 100
check("let str", name, "Alice")
check("let int", age, 30)
check("let float", pi_val, 3.14159)
check("let bool", active, true)
check("let null", nothing, null)
check("const", MAX_SIZE, 100)

// Integer literal separators
let million = 1_000_000
check("underscore int", million, 1000000)

// Assignment operators
let x = 42
x += 10
check("+=", x, 52)
x -= 5
check("-=", x, 47)
x *= 2
check("*=", x, 94)
x /= 2
check("/=", x, 47)

// Post-increment/decrement
x++
check("x++", x, 48)
x--
check("x--", x, 47)

// ═══════════════════════════════════════════════════════════
// CH04: Variable Scoping Rules
// ═══════════════════════════════════════════════════════════
let scope_x = 1
{
    let scope_x = 2
    check("inner shadow", scope_x, 2)
}
check("outer unaffected", scope_x, 1)

// Closures capture by reference
let count = 0
let inc = lambda() { count = count + 1 }
inc()
inc()
check("closure capture", count, 2)

// ═══════════════════════════════════════════════════════════
// CH05: Data Types
// ═══════════════════════════════════════════════════════════
check("type int", typeof(42), "int")
check("type str", typeof("hello"), "str")
check("type list", typeof([1, 2]), "list")
check("type bool", typeof(true), "bool")
check("type float", typeof(3.14), "float")
check("type null", typeof(null), "null")

// Type conversion
check("int(str)", int("42"), 42)
check("float(str)", float("3.14"), 3.14)
check("str(int)", str(42), "42")
check("bool(1)", bool(1), true)

// Collections
let lst = [1, 2, 3]
let dct = {"key": "value"}
let tpl = (1, "hello", true)
let st = #{1, 2, 3}
check("list type", typeof(lst), "list")
check("dict type", typeof(dct), "dict")
check("tuple type", typeof(tpl), "tuple")
check("set type", typeof(st), "set")

// Truthiness
check("null falsy", !null, true)
check("false falsy", !false, true)
check("0 falsy", !0, true)
check("empty str falsy", !"", true)
check("empty list falsy", ![], true)
check("nonempty truthy", !42, false)

// ═══════════════════════════════════════════════════════════
// CH06: Operators
// ═══════════════════════════════════════════════════════════
check("add", 3 + 4, 7)
check("sub", 10 - 3, 7)
check("mul", 5 * 6, 30)
check("div", 15 / 3, 5)
check("mod", 10 % 3, 1)
check("pow", 2 ** 10, 1024)
check("intdiv", 7 // 2, 3)

// String concat with +
check("str concat", "hello" + " " + "world", "hello world")

// Comparison
check("eq", 1 == 1, true)
check("neq", 1 != 2, true)
check("lt", 1 < 2, true)
check("gt", 2 > 1, true)
check("lte", 2 <= 2, true)
check("gte", 3 >= 2, true)

// Logical
check("and", true and true, true)
check("and false", true and false, false)
check("or", false or true, true)
check("not", not false, true)

// Ternary
check("ternary", (true ? "yes" : "no"), "yes")

// Null coalescing
check("??", null ?? "default", "default")
check("?? non-null", "val" ?? "default", "val")

// Range
let r = 0..5
check("range type", typeof(r), "range")

// ═══════════════════════════════════════════════════════════
// CH07: F-String Reference
// ═══════════════════════════════════════════════════════════
let fname = "World"
check("fstring", f"Hello ${fname}", "Hello World")
check("fstring expr", f"2+3=${2+3}", "2+3=5")

// ═══════════════════════════════════════════════════════════
// CH08: Strings
// ═══════════════════════════════════════════════════════════
let s = "Hello, World!"
check("str len", s.len(), 13)
check("str upper", "hello".upper(), "HELLO")
check("str lower", "HELLO".lower(), "hello")
check("str contains", "hello world".contains("world"), true)
check("str starts_with", "hello".starts_with("hel"), true)
check("str ends_with", "hello".ends_with("llo"), true)
check("str trim", "  hi  ".trim(), "hi")
check("str replace", "hello".replace("l", "r"), "herro")
check("str split", "a,b,c".split(","), ["a", "b", "c"])
check("str repeat", "ab".repeat(3), "ababab")
check("str replace", "hello".replace("l", "r"), "herro")
check("str index", "hello"[1], "e")
check("str slice", "hello"[1:3], "el")

// ═══════════════════════════════════════════════════════════
// CH09: Lists
// ═══════════════════════════════════════════════════════════
let items = [10, 20, 30]
check("list index", items[0], 10)
check("list len", items.len(), 3)
items.push(40)
check("list push", items.len(), 4)
check("list last", items[3], 40)
let popped = items.pop()
check("list pop", popped, 40)
check("list contains", items.contains(20), true)
check("list reverse", [1, 2, 3].reverse(), [3, 2, 1])
check("list join", ["a", "b", "c"].join(","), "a,b,c")
check("list slice", [1, 2, 3, 4][1:3], [2, 3])
check("list map", [1, 2, 3].map(lambda(x) => x * 2), [2, 4, 6])
check("list filter", [1, 2, 3, 4].filter(lambda(x) => x > 2), [3, 4])
check("list sort", [3, 1, 2].sort(), [1, 2, 3])

// ═══════════════════════════════════════════════════════════
// CH10: Dictionaries
// ═══════════════════════════════════════════════════════════
let d = {"name": "Alice", "age": 30}
check("dict access", d["name"], "Alice")
check("dict dot", d.name, "Alice")
check("dict keys", d.keys().sort(), ["age", "name"])
check("dict values len", d.values().len(), 2)
check("dict has", d.has("name"), true)
check("dict has false", d.has("xyz"), false)

// ═══════════════════════════════════════════════════════════
// CH11: Tuples
// ═══════════════════════════════════════════════════════════
let t = (1, "hello", true)
check("tuple index", t[0], 1)
check("tuple index 1", t[1], "hello")
check("tuple len", t.len(), 3)

// ═══════════════════════════════════════════════════════════
// CH12: Sets
// ═══════════════════════════════════════════════════════════
let s1 = #{1, 2, 3}
let s2 = #{3, 4, 5}
check("set union", s1.union(s2), #{1, 2, 3, 4, 5})
check("set intersect", s1.intersect(s2), #{3})
check("set diff", s1.difference(s2), #{1, 2})

// ═══════════════════════════════════════════════════════════
// CH13: Control Flow
// ═══════════════════════════════════════════════════════════
// if/else
let cf = 0
if (true) { cf = 1 }
check("if true", cf, 1)
if (false) { cf = 99 } else { cf = 2 }
check("if-else", cf, 2)

// elif
let val = 15
let grade = ""
if (val >= 20) { grade = "A" }
elif (val >= 10) { grade = "B" }
else { grade = "C" }
check("elif", grade, "B")

// for-in range
let sum = 0
for (i in 0..5) { sum = sum + i }
check("for range", sum, 10)

// while
let wh = 0
while (wh < 3) { wh = wh + 1 }
check("while", wh, 3)

// for-in list
let collected = []
for (item in [10, 20, 30]) { collected.push(item) }
check("for-in list", collected, [10, 20, 30])

// break/continue
let brk_sum = 0
for (i in 0..10) {
    if (i == 5) { break }
    brk_sum = brk_sum + i
}
check("break", brk_sum, 10)

let cont_sum = 0
for (i in 0..6) {
    if (i % 2 == 0) { continue }
    cont_sum = cont_sum + i
}
check("continue", cont_sum, 9)

// ═══════════════════════════════════════════════════════════
// CH14: Functions
// ═══════════════════════════════════════════════════════════
func add(a, b) { return a + b }
check("func call", add(3, 4), 7)

// Default params
func greet(name, greeting = "Hello") {
    return f"${greeting}, ${name}!"
}
check("default param", greet("Alice"), "Hello, Alice!")
check("override default", greet("Bob", "Hi"), "Hi, Bob!")

// Variadic
func sum_all(...args) {
    let total = 0
    for (a in args) { total = total + a }
    return total
}
check("variadic", sum_all(1, 2, 3, 4), 10)

// First-class functions
func apply(f, val) { return f(val) }
check("first-class", apply(lambda(x) => x * 2, 5), 10)

// Recursion
func factorial(n) {
    if (n <= 1) { return 1 }
    return n * factorial(n - 1)
}
check("recursion", factorial(5), 120)

// ═══════════════════════════════════════════════════════════
// CH15: Lambdas & Closures
// ═══════════════════════════════════════════════════════════
let double = lambda(x) => x * 2
check("lambda", double(5), 10)

// Closure
func make_counter() {
    let n = 0
    return lambda() { n = n + 1
        return n }
}
let counter = make_counter()
check("closure 1", counter(), 1)
check("closure 2", counter(), 2)
check("closure 3", counter(), 3)

// ═══════════════════════════════════════════════════════════
// CH16: Lazy Expressions
// ═══════════════════════════════════════════════════════════
let lazy_val = lazy 2 + 1
check("lazy eval", lazy_val, 3)

// ═══════════════════════════════════════════════════════════
// CH17: Classes
// ═══════════════════════════════════════════════════════════
class Animal {
    func constructor(name) {
        self.name = name
        self.sound = "..."
    }
    func speak() {
        return self.name + " says " + self.sound
    }
}
let cat = new Animal("Cat")
cat.sound = "Meow"
check("class basic", cat.speak(), "Cat says Meow")

// Inheritance
class Dog extends Animal {
    func constructor(name, breed) {
        super(name)
        self.breed = breed
        self.sound = "Woof"
    }
    func info() {
        return f"${self.name} (${self.breed})"
    }
}
let d1 = new Dog("Rex", "Husky")
check("class inherit", d1.speak(), "Rex says Woof")
check("class child method", d1.info(), "Rex (Husky)")

// ═══════════════════════════════════════════════════════════
// CH18: Fixed-Field Classes (@fixed)
// ═══════════════════════════════════════════════════════════
@fixed
class Point {
    func constructor(x, y) {
        self.x = x
        self.y = y
    }
}
let p = new Point(3, 4)
check("@fixed field", p.x, 3)

// ═══════════════════════════════════════════════════════════
// CH19: Data Classes (@data)
// ═══════════════════════════════════════════════════════════
@data
class Pair {
    func constructor(a, b) {
        self.a = a
        self.b = b
    }
}
let p1 = new Pair(1, 2)
let p2 = new Pair(1, 2)
check("@data class", p1.a, 1)

// ═══════════════════════════════════════════════════════════
// CH20: Sealed Classes
// ═══════════════════════════════════════════════════════════
sealed class Shape {}
class Circle extends Shape {
    func constructor(r) { self.r = r }
}
let c = new Circle(5)
check("sealed class", c.r, 5)

// ═══════════════════════════════════════════════════════════
// CH21: Copy-on-Write Classes (@cow)
// ═══════════════════════════════════════════════════════════
@cow
class Buffer {
    func constructor(data) { self.data = data }
}
let buf = new Buffer([1, 2, 3])
check("@cow", buf.data, [1, 2, 3])

// ═══════════════════════════════════════════════════════════
// CH22: Structs
// ═══════════════════════════════════════════════════════════
struct Vec2 { x, y }
let v = new Vec2(3, 4)
check("struct field", v.x, 3)

// ═══════════════════════════════════════════════════════════
// CH23: C Structs (cstruct)
// ═══════════════════════════════════════════════════════════
cstruct Pixel { r: int, g: int, b: int }
let px = new Pixel(255, 128, 0)
check("cstruct", px.r, 255)

// ═══════════════════════════════════════════════════════════
// CH24: `using` Keyword
// ═══════════════════════════════════════════════════════════
let u_obj = {"x": 10, "y": 20}
let u_result = 0
using u_obj {
    u_result = x + y
}
check("using", u_result, 30)

// ═══════════════════════════════════════════════════════════
// CH25: Traits
// ═══════════════════════════════════════════════════════════
trait Greetable {
    func greet_msg() { return "" }
}

class Greeter {
    func constructor(name) { self.name = name }
}

impl Greetable for Greeter {
    func greet_msg() {
        return "Hi, I'm " + self.name
    }
}
let gtr = new Greeter("Alice")
check("trait impl", gtr.greet_msg(), "Hi, I'm Alice")

// ═══════════════════════════════════════════════════════════
// CH26: Pipe and Spread
// ═══════════════════════════════════════════════════════════
func double_val(x) { return x * 2 }
func add_one(x) { return x + 1 }
let pipe_result = 5 |> double_val |> add_one
check("pipe", pipe_result, 11)

let a1 = [1, 2, 3]
let a2 = [0, ...a1, 4]
check("spread", a2, [0, 1, 2, 3, 4])

// ═══════════════════════════════════════════════════════════
// CH27: Enums
// ═══════════════════════════════════════════════════════════
enum Color {
    Red,
    Green,
    Blue
}
check("enum variant", str(Color.Red), "Color.Red")

// ═══════════════════════════════════════════════════════════
// CH28: Pattern Matching
// ═══════════════════════════════════════════════════════════
let match_val = 42
let match_res = match (match_val) {
    case (1) { "one" }
    case (42) { "forty-two" }
    case (_) { "other" }
}
check("match", match_res, "forty-two")

// ═══════════════════════════════════════════════════════════
// CH29: Error Handling
// ═══════════════════════════════════════════════════════════
let ok_val = Ok(42)
let err_val = Err("oops")
check("ok unwrap", ok_val.unwrap(), 42)
check("err is_err", err_val.is_err(), true)
check("ok is_ok", ok_val.is_ok(), true)

let opt = Some(10)
check("some unwrap", opt.unwrap(), 10)
check("none unwrap_or", None.unwrap_or(5), 5)

// try/catch
let caught = ""
try {
    throw "error!"
} catch (e) {
    caught = e
}
check("try/catch", caught, "error!")

// ═══════════════════════════════════════════════════════════
// CH30: Generators
// ═══════════════════════════════════════════════════════════
func* range_gen(n) {
    let i = 0
    while (i < n) {
        yield i
        i = i + 1
    }
}
let gen_result = []
for (v in range_gen(3)) {
    gen_result.push(v)
}
check("generator", gen_result, [0, 1, 2])

// ═══════════════════════════════════════════════════════════
// CH31: Async / Await (synchronous fallback)
// ═══════════════════════════════════════════════════════════
async func async_add(a, b) { return a + b }
let async_result = await async_add(3, 4)
check("async/await", async_result, 7)

// ═══════════════════════════════════════════════════════════
// CH32: Macros
// ═══════════════════════════════════════════════════════════
macro double_ch!(val) {
    return val * 2
}
check("macro call", double_ch!(21), 42)

// ═══════════════════════════════════════════════════════════
// CH33: Compile-Time Execution
// ═══════════════════════════════════════════════════════════
comptime {
    let ct_val = 1 + 1
}
check("comptime block", true, true)

