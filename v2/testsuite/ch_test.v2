// ═══════════════════════════════════════════════════════════
// CH36: Decorators
// ═══════════════════════════════════════════════════════════
// Decorator test - basic application
check("decorator", true, true)

// ═══════════════════════════════════════════════════════════
// CH37: Operator Overloading
// ═══════════════════════════════════════════════════════════
class Vec2D {
    func constructor(x, y) {
        self.x = x
        self.y = y
    }
    func __add__(other) {
        return new Vec2D(self.x + other.x, self.y + other.y)
    }
}
let v1 = new Vec2D(1, 2)
let v2 = new Vec2D(3, 4)
let v3 = v1 + v2
check("op overload x", v3.x, 4)
check("op overload y", v3.y, 6)

// ═══════════════════════════════════════════════════════════
// CH38: Testing
// ═══════════════════════════════════════════════════════════
test "basic assertion" {
    assert_eq(1 + 1, 2)
}
check("test block", true, true)

// ═══════════════════════════════════════════════════════════
// CH39: Builtins Reference
// ═══════════════════════════════════════════════════════════
check("len", len([1, 2, 3]), 3)
check("abs", abs(-5), 5)
check("min", min(3, 1, 2), 1)
check("max", max(3, 1, 2), 3)
check("range builtin", str(range(3)), "0..3")
check("chr", chr(65), "A")
check("ord", ord("A"), 65)

