// ═══════════════════════════════════════════════════════════
// CH: Memory Safety and Borrowing
// ═══════════════════════════════════════════════════════════
let orig = 42
let ref_val = &orig
check("borrow immut", ref_val, 42)
let mut_val = 10
let mr = &mut mut_val
check("borrow mut", mr, 10)
let derefed = *ref_val
check("deref", derefed, 42)

