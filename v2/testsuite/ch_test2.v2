// ═══════════════════════════════════════════════════════════
// CH: Union Types
// ═══════════════════════════════════════════════════════════
func accept_union(x: int | str) -> int | str {
    return x
}
check("union int", accept_union(42), 42)
check("union str", accept_union("hi"), "hi")

// ═══════════════════════════════════════════════════════════
// CH: The never Type
// ═══════════════════════════════════════════════════════════
func might_panic(x) -> never | int {
    if (x < 0) { throw "negative!" }
    return x
}
check("never positive", might_panic(5), 5)
let never_caught = false
try {
    might_panic(-1)
} catch (e) {
    never_caught = true
}
check("never throws", never_caught, true)

