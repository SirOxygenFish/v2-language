// ═══════════════════════════════════════════════════════════
// CH: Built-in Trait Catalog
// ═══════════════════════════════════════════════════════════
trait Clone_ {
    func clone_self() { return null }
}
trait Display_ {
    func display() { return "" }
}
class MyVal {
    func constructor(v) { self.v = v }
}
impl Clone_ for MyVal {
    func clone_self() {
        return new MyVal(self.v)
    }
}
impl Display_ for MyVal {
    func display() {
        return "MyVal(" + str(self.v) + ")"
    }
}
let mv = new MyVal(10)
let mv2 = mv.clone_self()
check("trait cat clone", mv2.v, 10)
check("trait cat display", mv.display(), "MyVal(10)")

// ═══════════════════════════════════════════════════════════
// CH: Sendable
// ═══════════════════════════════════════════════════════════
trait Sendable2 {}
class SafeData {
    func constructor(x) { self.x = x }
}
impl Sendable2 for SafeData {}
let sd = new SafeData(42)
check("sendable marker", sd.x, 42)
let sent = unsafe_send(sd)
check("sendable send", sent.x, 42)

