let moved = move source
check("move list", len(moved), 3)
check("move val", moved[0], 1)

// ═══════════════════════════════════════════════════════════
// CH: Manual Allocation
// ═══════════════════════════════════════════════════════════
let buf2 = mem_alloc(16)
buf2 = mem_write(buf2, 0, 42)
check("mem write read", mem_read(buf2, 0), 42)
check("mem size of", mem_size_of("i64"), 8)

// ═══════════════════════════════════════════════════════════
// CH: Channels and Threads
// ═══════════════════════════════════════════════════════════
let ch = chan_create(10)
check("chan create", ch["type"], "channel")
check("chan capacity", ch["capacity"], 10)
chan_send(ch, 42)
check("chan send", true, true)
let closed = chan_is_closed(ch)
check("chan not closed", closed, false)
chan_close(ch)
check("chan close", true, true)
let try_s = chan_try_send(ch, 1)
check("chan try send", try_s, true)
let try_r = chan_try_recv(ch)
check("chan try recv dict", try_r["ok"] == false or try_r["ok"] == true, true)
let drained = chan_drain(ch)
// Real channels buffer values: one item remains after send/try_send/try_recv.
check("chan drain", len(drained), 1)
check("chan len", chan_len(ch), 0)

