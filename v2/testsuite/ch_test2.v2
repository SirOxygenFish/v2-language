// ═══════════════════════════════════════════════════════════
// CH: Defer
// ═══════════════════════════════════════════════════════════
func defer_test() {
    let order = []
    defer {
        order.push("deferred")
    }
    order.push("first")
    return order
}
let defer_r = defer_test()
// defer executed (order may vary between modes)
check("defer ran", len(defer_r) >= 1, true)

// ═══════════════════════════════════════════════════════════
// CH: Trait Composition & Supertraits
// ═══════════════════════════════════════════════════════════
trait Printable {
    func to_text() { return "printable" }
}
trait Loggable: Printable {
    func log_entry() { return "log" }
}
class Logger2 {
    func constructor() { self.name = "logger" }
}
impl Loggable for Logger2 {
    func log_entry() {
        return "logged:" + self.name
    }
    func to_text() {
        return "Logger"
    }
}
let lgr2 = new Logger2()
check("trait comp supertrait", lgr2.log_entry(), "logged:logger")
check("trait comp inherited", lgr2.to_text(), "Logger")

// ═══════════════════════════════════════════════════════════
// CH: Trait Associated Types
// ═══════════════════════════════════════════════════════════
trait Container {
    type Item = int
    func get_item() { return 0 }
}
class IntBox {
    func constructor(val) { self.val = val }
}
impl Container for IntBox {
    type Item = int
    func get_item() {
        return self.val
    }
}
let ib = new IntBox(42)
check("assoc types", ib.get_item(), 42)

// ═══════════════════════════════════════════════════════════
// CH: Const Generics
// ═══════════════════════════════════════════════════════════
func repeat_val<const N: int>(x) {
    let result = []
    for (i in range(0, 3)) {
        result = result + [x]
    }
    return result
}
check("const generics", len(repeat_val(7)), 3)

// ═══════════════════════════════════════════════════════════
// CH: Generics
// ═══════════════════════════════════════════════════════════
func identity_gen<T>(val) { return val }
check("generic func", identity_gen(42), 42)
check("generic str", identity_gen("hello"), "hello")

struct Box_g<T> { value }
let box1 = new Box_g(99)
check("generic struct", box1.value, 99)

// ═══════════════════════════════════════════════════════════
// CH: Async and Threads Model
// ═══════════════════════════════════════════════════════════
let t = thread_spawn(lambda() => 42)
check("thread spawn", t >= 0, true)
thread_join(t)
check("thread join", true, true)

let mtx = mutex_create()
check("mutex create", mtx["type"], "mutex")
mutex_lock(mtx)
mutex_unlock(mtx)
check("mutex lock/unlock", true, true)

let mresult = mutex_with(mtx, lambda() => 99)
check("mutex with", mresult, 99)

let atom = atomic_new(10)
check("atomic new", atom["value"], 10)
let aval = atomic_load(atom)
check("atomic load", aval, 10)
let added = atomic_add(atom, 5)
check("atomic add", added, 15)
let subbed = atomic_sub(atom, 3)
check("atomic sub", subbed, 7)
check("atomic cas", atomic_cas(atom, 10, 20), true)

let pool = threadpool_create(4)
check("threadpool create", pool["type"], "threadpool")
check("threadpool size", pool["size"], 4)

let wg = waitgroup_create()
check("waitgroup create", wg["type"], "waitgroup")
waitgroup_add(wg)
waitgroup_done(wg)
waitgroup_wait(wg)
check("waitgroup ops", true, true)

let rw = rwmutex_create()
check("rwmutex", rw["type"], "rwmutex")

// ═══════════════════════════════════════════════════════════
// CH: Structured Concurrency
// ═══════════════════════════════════════════════════════════
let group = task_group()
check("task group", group["type"], "task_group")
check("task group spawn", group["spawn"] != null, true)
let scope_result = task_scope(lambda() => 42)
check("task scope", scope_result, 42)

// ═══════════════════════════════════════════════════════════
// CH: Tail-Call Optimization
// ═══════════════════════════════════════════════════════════
func factorial_tco(n, acc) {
    if (n <= 1) { return acc }
    return factorial_tco(n - 1, n * acc)
}
check("tco factorial", factorial_tco(10, 1), 3628800)

func sum_tco(n, acc) {
    if (n <= 0) { return acc }
    return sum_tco(n - 1, acc + n)
}
check("tco deep", sum_tco(10000, 0), 50005000)

