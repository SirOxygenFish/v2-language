// Chapter verification tests - Part 2
// Covers remaining 🟩 chapters not in ch_test.v2

let pass = 0
let fail = 0
func check(lbl, got, expected) {
    if (got == expected) {
        pass = pass + 1
    } else {
        fail = fail + 1
        print(f"FAIL: ${lbl} | got=${got} expected=${expected}")
    }
}

